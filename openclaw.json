{
  "version": "2026.3.3",

  "gateway": {
    "mode": "local",
    "bind": "127.0.0.1",
    "port": 18789,
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "tailscale": {
      "mode": "off"
    }
  },

  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "http://127.0.0.1:11434",
        "apiKey": "ollama-local",
        "api": "openai-completions",
        "models": [
          {
            "id": "qwen3:8b",
            "name": "Qwen3-8B",
            "api": "openai-completions",
            "input": ["text"],
            "contextWindow": 32768,
            "maxTokens": 8192
          },
          {
            "id": "qwen3:4b",
            "name": "Qwen3-4B",
            "api": "openai-completions",
            "input": ["text"],
            "contextWindow": 32768,
            "maxTokens": 8192
          }
        ]
      },
      "dashscope": {
        "baseUrl": "https://dashscope.aliyuncs.com/compatible-mode/v1",
        "apiKey": "${BAILIAN_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "qwen3.6-plus",
            "name": "Qwen3.6-Plus",
            "api": "openai-completions",
            "input": ["text", "image"],
            "contextWindow": 1000000,
            "maxTokens": 65536
          },
          {
            "id": "qwen3.5-plus",
            "name": "Qwen3.5-Plus",
            "api": "openai-completions",
            "input": ["text", "image"],
            "contextWindow": 1000000,
            "maxTokens": 65536
          },
          {
            "id": "qwen-max",
            "name": "Qwen-Max",
            "api": "openai-completions",
            "input": ["text"],
            "contextWindow": 131072,
            "maxTokens": 65536
          },
          {
            "id": "qwen-plus-2025-07-28",
            "name": "Qwen-Plus-2025-07-28",
            "api": "openai-completions",
            "input": ["text"],
            "contextWindow": 131072,
            "maxTokens": 65536
          }
        ]
      },
      "deepseek": {
        "baseUrl": "https://api.deepseek.com",
        "apiKey": "${DEEPSEEK_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "deepseek-chat",
            "name": "DeepSeek Chat V3",
            "api": "openai-completions",
            "input": ["text"],
            "contextWindow": 128000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },

  "agents": {
    "defaults": {
      "model": {
        "primary": "ollama/qwen3:8b",
        "fallbacks": [
          "dashscope/qwen3.6-plus",
          "dashscope/qwen3.5-plus",
          "ollama/qwen3:4b"
        ]
      },
      "workspace": "E:/OpenClaw/workspace",
      "compaction": {
        "mode": "safeguard"
      },
      "maxConcurrent": 3,
      "subagents": {
        "maxConcurrent": 6
      }
    }
  },

  "tools": {
    "profile": "coding"
  },

  "logging": {
    "level": "info",
    "consoleLevel": "info",
    "redactSensitive": "tools"
  },

  "commands": {
    "native": true,
    "nativeSkills": true,
    "restart": true
  },

  "session": {
    "dmScope": "per-channel-peer"
  },

  "cron": {
    "enabled": true
  },

  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "boot-md": {
          "enabled": true
        },
        "command-logger": {
          "enabled": true
        },
        "session-memory": {
          "enabled": true
        }
      }
    }
  },

  "plugins": {
    "enabled": true,
    "allow": [
      "dingtalk",
      "qqbot",
      "wecom",
      "feishu-china"
    ]
  }
}
